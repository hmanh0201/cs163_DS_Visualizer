{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build DS Visualizer (g++)", // Tên này phải khớp với preLaunchTask
            "type": "shell",
            "command": "g++",
            "args": [
                "-g",
                "src/main.cpp",
                "-o",
                "DSVisualizer.exe", // Đổi tên file output ở đây
                "-I${workspaceFolder}/include",
                "-L${workspaceFolder}/lib",
                "-lraylib",
                "-lopengl32",
                "-lgdi32",
                "-lwinmm",
                "-static"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}